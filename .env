# ─────────────────────────────────────────────────────────────────────────────
# Caryanams DMS — Environment Variables (PostgreSQL)
# Copy this file and fill in your actual values before running the app.
# NEVER commit the filled-in .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL Database URL ────────────────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://postgres:dkc190802@localhost:5432/caryanams_db

# ── Flask Secret Key ──────────────────────────────────────────────────────
# Change this to a long random string in production
SECRET_KEY=Caryanams-secret-2025-xK9mP

# ── App Base URL (for minisite links) ────────────────────────────────────
APP_URL=http://localhost:5000

# ── Razorpay Payment Gateway ──────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── Bank / UPI Fallback Details ───────────────────────────────────────────
UPI_ID=caryanams@upi
